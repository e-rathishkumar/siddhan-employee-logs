# Siddhan Employee Logs - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# JWT secret for token signing (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=

# Default admin credentials (used during initial seed)
DEFAULT_ADMIN_EMAIL=admin@siddhan.com
DEFAULT_ADMIN_PASSWORD=Siddhan@123

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=
